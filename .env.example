# Optional override: if omitted, token contract is resolved via score contract `token_id()`.
VITE_TOKEN_CONTRACT_ID=CBUCDXT6BY3WWP764AMW66QJA6ZRWL2TRV6VTYCWPZF4FUZRAXK2S253

