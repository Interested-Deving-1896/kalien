{
  "name": "kalien",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js dev",
    "dev:rpc-proxy": "bun run scripts/dev-rpc-proxy.ts",
    "build": "vite build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "deploy": "vite build && wrangler deploy",
    "typegen": "WRANGLER_LOG_PATH=.wrangler/logs wrangler types",
    "typegen:check": "WRANGLER_LOG_PATH=.wrangler/logs wrangler types --check",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:worker": "tsc --noEmit -p worker/tsconfig.json",
    "typecheck:scripts": "tsc --noEmit -p scripts/tsconfig.json",
    "typecheck": "bun run typegen:check && bun run typecheck:app && bun run typecheck:node && bun run typecheck:worker && bun run typecheck:scripts",
    "lint": "oxlint src worker",
    "lint:fix": "oxlint src worker --fix",
    "format": "oxfmt src worker --write",
    "format:check": "oxfmt src worker --check",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "verify-tape": "bun run scripts/verify-tape.ts",
    "generate-tape": "bun run scripts/generate-tape.ts",
    "generate:score-bindings": "bash ./scripts/generate-score-bindings.sh",
    "verify-tape:risc0": "bun run scripts/verify-tape-risc0.ts",
    "bench:risc0": "bash ./scripts/bench-risc0.sh"
  },
  "dependencies": {
    "@fontsource/monaspace-krypton": "^5.2.5",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@openzeppelin/relayer-plugin-channels": "^0.13.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.2",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "smart-account-kit": "^0.2.9",
    "smart-account-kit-bindings": "^0.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.5",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.68.1"
  }
}
