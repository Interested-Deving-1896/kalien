{
  "name": "kalien-cli",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "kalien": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/kalien",
    "build:linux-x64": "bun build src/index.ts --compile --outfile dist/kalien-linux-x64 --target bun-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --outfile dist/kalien-linux-arm64 --target bun-linux-arm64",
    "build:macos-x64": "bun build src/index.ts --compile --outfile dist/kalien-macos-x64 --target bun-darwin-x64",
    "build:macos-arm64": "bun build src/index.ts --compile --outfile dist/kalien-macos-arm64 --target bun-darwin-arm64",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:macos-x64 && bun run build:macos-arm64"
  }
}
