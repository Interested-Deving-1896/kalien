# Test script secrets — copy to scripts/.env and fill in values.
# scripts/.env is gitignored.

# ── Secrets ────────────────────────────────────────────────────────────────
# Private key for submitting Boundless proof orders (test-boundless-submit).
BOUNDLESS_PRIVATE_KEY=0x...
# Pinata JWT for IPFS uploads (stdin payloads, ELF bundles).
PINATA_JWT=
# Relayer API key for Stellar claim submission (test-boundless-submit, e2e).
RELAYER_API_KEY=
# Optional Boundless collateral amount in ZKC (18 decimals on-chain; default 5).
BOUNDLESS_LOCK_COLLATERAL_ZKC=5

# ── Non-secret overrides ──────────────────────────────────────────────────
# Stellar RPC endpoint (used by generate-tape to fetch on-chain seed).
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# Score contract for seed lookup and direct-submit tests.
SCORE_CONTRACT_ID=CAKVUHDKKEG6SYUAVMQMDRMUGCNQJS74BP45NNYS7Y2TTYUMYFSLA7EU
# Network passphrase for Stellar transaction signing.
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
