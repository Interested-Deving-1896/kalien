# Contract deployment and testing — copy to kalien-contract/.env.
# kalien-contract/.env is gitignored.

# ── Contract addresses ────────────────────────────────────────────────────
# Score contract ID (deployed via deploy-and-test.sh).
SCORE_CONTRACT_ID=
# SAC token contract ID (created via `stellar contract asset deploy`).
TOKEN_ID=

# ── Stellar CLI identities ───────────────────────────────────────────────
# `stellar keys` identity used for contract deployment.
DEPLOYER_NAME=default
# `stellar keys` identity used as the player in test submissions.
PLAYER_NAME=player2

# ── Verifier image ───────────────────────────────────────────────────────
# RISC Zero image ID (hex, no 0x prefix) for the kalien-verifier guest.
# Must match the R0BF bundle uploaded to IPFS / configured in wrangler.jsonc.
IMAGE_ID_HEX=

# ── Deploy bookkeeping (optional) ────────────────────────────────────────
# Transaction hashes from the last deployment — useful for cost analysis.
DEPLOY_TX_HASH=
SAC_TX_HASH=
